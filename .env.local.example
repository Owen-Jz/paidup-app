# Copy to .env.local and fill from your gitignored smoke-test/.env (TEST creds + sandbox)
NOMBA_BASE=https://sandbox.nomba.com
NOMBA_ACCOUNT_ID=               # parent account id -> accountId header
NOMBA_SUB_ACCOUNT_ID=           # collections sub-account -> create VAs under this
NOMBA_CLIENT_ID=                # TEST client id
NOMBA_CLIENT_SECRET=            # TEST private key
NOMBA_WEBHOOK_SECRET=           # signature key from Dashboard -> Developer -> Webhook Setup

# --- demo / safety flags ---
# Production fails CLOSED: with NODE_ENV=production and no NOMBA_WEBHOOK_SECRET, the webhook returns 503,
# and /api/simulate returns 404. For local demos use `npm run dev` (these gates are dev-open).
# For a HOSTED demo without a real secret, opt in explicitly:
ALLOW_UNSIGNED_WEBHOOKS=        # =1 to accept unsigned webhooks in production (demo only)
DEMO_MODE=                      # =1 to keep /api/simulate enabled in production (demo only)

# --- auth (multi-tenant) ---
# Signs the stateless session tokens (HMAC-SHA256). REQUIRED in production (auth fails closed / 503
# without it); dev falls back to a fixed local-only secret. Generate: openssl rand -hex 32
SESSION_SECRET=
# Password for the pre-seeded demo workspace (demo@paidup.app). Defaults to LedgerDemo2026.
DEMO_PASSWORD=

# --- AI moat (OPTIONAL — MiniMax) ---
# Powers the AI unmatched-payment resolver (/api/resolve), anomaly explanations (/api/explain), and the
# reconciliation brief (/api/summary). EVERY AI feature degrades gracefully: if this key is unset, rate
# limited, slow, or errors, the app falls back to its deterministic engine and the demo is UNAFFECTED.
# AI only ever SUGGESTS — it never moves money and is hard-grounded to real ledger state (no hallucinated
# invoice ids/amounts). Leave BLANK to run the app fully deterministic.
MINIMAX_API_KEY=
MINIMAX_BASE=https://api.minimax.io/v1   # optional override
MINIMAX_MODEL=MiniMax-Text-01            # optional override
MINIMAX_TIMEOUT_MS=8000                  # optional: fall back to deterministic if MiniMax is slower than this
